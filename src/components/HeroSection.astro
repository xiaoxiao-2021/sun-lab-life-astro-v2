---
import DeskPanel from "./DeskPanel.astro";
import CurrentFocus from "./CurrentFocus.astro";

const base = import.meta.env.BASE_URL;
---

<main class="hero-section">
  <section class="hero-card">
    <p class="eyebrow">Clinical Medicine · Research · Life</p>

    <h1>Sun's Lab & Life</h1>

    <p class="hero-subtitle">
      一个医学科研人的数字小窝。
    </p>

    <p class="hero-subline">
      A quiet space for medicine, research, bioinformatics, photography, and becoming myself.
    </p>

    <p class="hero-text">
      这里记录我的科研、生信、摄影、日语学习和生活成长。
      我正在慢慢成为一个更有主见、更有执行力、更会爱自己的人。
    </p>

    <div class="tags">
      <span>ADCY7</span>
      <span>Tumor Immunity</span>
      <span>Bioinformatics</span>
      <span>Photography</span>
      <span>Japanese</span>
    </div>

    <div class="hero-actions">
      <a href={`${base}research/`} class="primary-btn">Enter Research</a>
      <a href={`${base}bioinformatics/`} class="secondary-btn">View Workflow</a>
    </div>

    <CurrentFocus />
  </section>

  <DeskPanel />
</main>