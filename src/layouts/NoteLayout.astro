---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter, headings = [] } = Astro.props;

const tocHeadings = headings.filter((heading) => {
  return heading.depth === 2 || heading.depth === 3;
});
---

<BaseLayout title={`${frontmatter.title} | Sun's Lab & Life`}>
  <article class="note-page">
    <header class="note-header">
      <p class="eyebrow">{frontmatter.category}</p>

      <h1>{frontmatter.title}</h1>

      <p class="note-description">
        {frontmatter.description}
      </p>

      <div class="note-meta">
        <span>{frontmatter.date.toLocaleDateString("zh-CN")}</span>

        {frontmatter.status && (
          <span>{frontmatter.status}</span>
        )}
      </div>

      <div class="note-tags">
        {frontmatter.tags.map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </header>

    <div class="note-shell">
      <div class="note-content">
        <slot />
      </div>

      {tocHeadings.length > 0 && (
        <aside class="note-toc">
          <div class="note-toc-card">
            <p class="note-toc-title">目录</p>

            <nav>
              {tocHeadings.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class={`toc-depth-${heading.depth}`}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>

  <script>
    const tocLinks = Array.from(document.querySelectorAll(".note-toc a"));

    const headings = tocLinks
      .map((link) => {
        const id = decodeURIComponent(
          link.getAttribute("href")?.replace("#", "") || ""
        );

        return document.getElementById(id);
      })
      .filter(Boolean);

    function updateActiveToc() {
      if (!headings.length) return;

      let currentHeading = headings[0];

      for (const heading of headings) {
        const rect = heading.getBoundingClientRect();

        if (rect.top <= 150) {
          currentHeading = heading;
        } else {
          break;
        }
      }

      tocLinks.forEach((link) => {
        const linkId = decodeURIComponent(
          link.getAttribute("href")?.replace("#", "") || ""
        );

        const isActive = linkId === currentHeading.id;

        link.classList.toggle("active", isActive);

        if (isActive) {
          link.scrollIntoView({
            block: "nearest",
            behavior: "smooth",
          });
        }
      });
    }

    window.addEventListener("scroll", updateActiveToc, { passive: true });
    window.addEventListener("load", updateActiveToc);

    updateActiveToc();
  </script>
</BaseLayout>